{
  "manifest_version": 3,
  "name": "rym-hide-ratings",
  "version": "1.0",

  "description": "Hides rateyourmusic release/track ratings until user has rated the release.",

  "icons": {
    "32": "icons/star.svg",
    "64": "icons/star.svg",
    "96": "icons/star.svg",
    "128": "icons/star.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "rym-hide-ratings@mozilla.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["*://rateyourmusic.com/*"],
      "js": ["rym-hide-ratings.js"],
      "run_at": "document_start"
    }
  ]
}
